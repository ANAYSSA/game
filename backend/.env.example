# Server Configuration
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins allowed to connect
# In production, set this to your Vercel domain
CORS_ORIGIN=http://localhost:8080,http://localhost:5500,http://127.0.0.1:8080

